# Supabase project credentials.
#
# Copy this file to `.env` and fill in the values:
#   - For a hosted project: Supabase dashboard → Project Settings → API.
#   - For local dev: run `supabase start` and use the printed API URL + anon key.
#
# These vars are inlined into the client bundle by Vite, so only ever use the
# public anon key here — never the service_role key.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
