# Supabase project credentials.
#
# Copy this file to `.env` and fill in the values:
#   - For a hosted project: Supabase dashboard → Project Settings → API keys.
#   - For local dev: run `supabase start` and use the printed API URL + key.
#
# VITE_SUPABASE_ANON_KEY holds the client-side key read by src/lib/supabase.ts.
# Use the public, browser-safe key. Both formats work with supabase-js here:
#   - New style: a publishable key, prefixed `sb_publishable_…` (recommended).
#   - Legacy:    the anon JWT (starts `eyJ…`).
# These vars are inlined into the client bundle by Vite, so NEVER put the
# service_role / secret key here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your-publishable-key
